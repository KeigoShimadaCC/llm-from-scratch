      "parallelGroup": "core",
      "automerge": true,
      "validationCommands": [
        {
          "id": "phase-01a-overfit-smoke",
          "command": "uv run python -m train.micro_char --config configs/micro_char.yaml --max-steps 200 --run-name phase01a_overfit_smoke",
          "timeoutMs": 600000,
          "requiredFor": [
