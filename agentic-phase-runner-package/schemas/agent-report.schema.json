{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Agent Structured Report",
  "type": "object",
  "required": ["schemaVersion", "phase", "status"],
  "properties": {
    "schemaVersion": { "const": 1 },
    "phase": { "type": "string" },
    "status": { "enum": ["pass", "blocked", "fail"] },
    "summary": { "type": "string" },
    "filesChanged": { "type": "array", "items": { "type": "string" } },
    "commandsRun": { "type": "array" },
    "blockingGaps": { "type": "array", "items": { "type": "string" } }
  }
}
