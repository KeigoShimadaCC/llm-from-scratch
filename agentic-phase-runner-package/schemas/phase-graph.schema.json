{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Agentic Phase Graph",
  "type": "object",
  "required": ["schemaVersion", "defaultStartPhase", "defaultParallelism", "globalValidationCommands", "phases"],
  "properties": {
    "schemaVersion": { "const": 1 },
    "defaultStartPhase": { "type": "string" },
    "defaultParallelism": { "type": "integer", "minimum": 1 },
    "globalValidationCommands": { "type": "array", "items": { "type": "string" } },
    "phases": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "plan", "dependsOn", "allowedPaths", "parallelGroup", "automerge"],
        "properties": {
          "id": { "type": "string" },
          "plan": { "type": "string" },
          "dependsOn": { "type": "array", "items": { "type": "string" } },
          "allowedPaths": { "type": "array", "items": { "type": "string" } },
          "parallelGroup": { "type": "string" },
          "automerge": { "type": "boolean" }
        }
      }
    }
  }
}
