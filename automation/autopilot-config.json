{
  "agents": {
    "cursorSubtask": {
      "commandTemplate": "agent --print --trust --workspace '{{WORKSPACE}}' \"$(cat '{{PROMPT_PATH}}')\"",
      "inactivityTimeoutMs": 180000,
      "maxRetries": 0,
      "provider": "manual",
      "timeoutMs": 900000
    },
    "executor": {
      "commandTemplate": "codex exec --sandbox workspace-write --add-dir '{{EVIDENCE_DIR}}' --add-dir /private/tmp --json --output-last-message '{{OUTPUT_PATH}}' - < '{{PROMPT_PATH}}'",
      "inactivityTimeoutMs": 1200000,
      "maxRetries": 0,
      "provider": "shell",
      "timeoutMs": 3600000
    },
    "planner": {
      "commandTemplate": "codex exec --sandbox workspace-write --add-dir '{{EVIDENCE_DIR}}' --add-dir /private/tmp --json --output-last-message '{{OUTPUT_PATH}}' - < '{{PROMPT_PATH}}'",
      "inactivityTimeoutMs": 1200000,
      "maxRetries": 0,
      "provider": "shell",
      "timeoutMs": 3600000
    },
    "rechecker": {
      "commandTemplate": "codex exec --sandbox workspace-write --add-dir '{{EVIDENCE_DIR}}' --add-dir /private/tmp --json --output-last-message '{{OUTPUT_PATH}}' - < '{{PROMPT_PATH}}'",
      "inactivityTimeoutMs": 1200000,
      "maxRetries": 0,
      "provider": "shell",
      "timeoutMs": 1800000
    }
  },
  "commandExecutor": {
    "defaultTimeoutMs": 3600000,
    "inactivityTimeoutMs": 1200000,
    "maxRetries": 0
  },
  "dependencyBootstrapCommands": [],
  "git": {
    "baseBranch": "main",
    "baseRef": "origin/main"
  },
  "preflightCommands": [
    "git status --short --branch"
  ],
  "restrictedAgentDelegate": {
    "commandIds": [],
    "enabled": false,
    "evidenceDirName": "restricted-agent-tasks",
    "maxAttempts": 1,
    "patchBudget": {
      "maxBytes": 2000,
      "maxFiles": 1
    },
    "providerMode": "fake"
  },
  "schemaVersion": 1
}
