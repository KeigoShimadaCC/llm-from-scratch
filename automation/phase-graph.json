        ".gitignore",
        "README.md",
        "NORTH_STAR.md",
        "pyproject.toml",
        "uv.lock",
        "configs/**",
        "data/README.md",
        "docs/**",
        "kgpt/**",
        "tokenizer/**",
        "train/**",
        "eval/**",
        "inference/**",
        "experiments/README.md",
        "tests/**",
        "PROGRESS.md"
      ],
      "parallelGroup": "foundation",
      "automerge": true,
      "validationCommands": [
        {
          "id": "phase-00b-dummy-training-smoke",
          "command": "uv run python -m train.dummy --config configs/dummy.yaml --run-name phase00b_smoke",
          "timeoutMs": 300000,
          "requiredFor": [
            "phase",
            "merge"
          ]
        },
        {
          "id": "phase-00b-env-smoke",
          "command": "uv run python -m kgpt.env_check --optional-mps",
          "timeoutMs": 120000,
          "requiredFor": [
            "phase",
            "merge"
          ]
        }
      ]
    },
    {
